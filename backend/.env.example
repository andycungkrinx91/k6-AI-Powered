# Database
DATABASE_URL=mysql+aiomysql://k6user:k6password@127.0.0.1:3306/k6ai

# Backend Keys
BACKEND_API_KEY=super_secret_key
BACKEND_ADMIN_KEY=super_secret_admin_key
CAPTCHA_SECRET=your_internal_secret

# LLM Provider Configuration
# Options: gemini, openai
LLM_PROVIDER=gemini

# Gemini Configuration
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.2

# OpenAI / OpenAI-Compatible (vLLM, Ollama, etc.)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.2

# Auth (JWT)
AUTH_SECRET=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Initial admin bootstrap
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_me

# Storage & CORS
RESULT_DIR=./results
CORS_ORIGINS=http://localhost:3000
USER_AGENT=k6-ai-powerd-agent
