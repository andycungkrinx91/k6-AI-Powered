# Copy this file to scripts/.env and adjust values.
# This file is loaded by scripts/run-backend-ubuntu.sh and scripts/run-frontend-ubuntu.sh before defaults.

# Backend bind settings
HOST=0.0.0.0
PORT=8000

# Set to 1 to skip database initialization
SKIP_DB_INIT=1

# Set to 1 to install lighthouse globally with npm
INSTALL_LIGHTHOUSE=1

# Application database settings
DB_NAME=k6ai
DB_USER=k6user
DB_PASSWORD=k6password
DB_HOST=127.0.0.1
DB_PORT=3306

# Backend auth (JWT)
# IMPORTANT: set a long random secret in production.
AUTH_SECRET=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Initial admin bootstrap (kept in sync on backend startup)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_me

# Frontend bind settings
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# Frontend run mode: dev|start
FRONTEND_MODE=start

# Frontend environment (used to generate frontend/.env if missing)
BACKEND_API_URL=http://127.0.0.1:8000
BACKEND_API_KEY=

# Set to 1 to auto-install Node.js 24.x via NodeSource if needed
INSTALL_NODE_24=0
